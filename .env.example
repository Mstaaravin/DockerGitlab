VERSION=18.x.x-ce.0
TZ=America/Argentina/Buenos_Aires

# Optional services: runner (comma-separated, or leave empty for GitLab + Traefik only)
COMPOSE_PROFILES=

# Runner token obtained from GitLab UI: Admin > CI/CD > Runners > New instance runner
RUNNER_TOKEN=<gitlab-runner-registration-token>

GITLAB_DOMAIN=<gitlab-hostname>
REGISTRY_DOMAIN=<registry-hostname>
TRAEFIK_DOMAIN=<traefik-hostname>
GITLAB_IP=<server-ip>
RUNNER_DOCKER_IMAGE=docker:27
