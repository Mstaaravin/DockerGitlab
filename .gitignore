gitlab/data/
gitlab/logs/

.env
.env.*
!.env.example

# Certificates and private keys (environment-specific, deploy via rsync)
traefik/certs/*.crt
traefik/certs/*.key
gitlab/config/ssl/*.crt
gitlab/config/ssl/*.key

# SSH host keys (server-specific, auto-generated by GitLab Omnibus)
gitlab/config/ssh_host_*

# GitLab runtime secrets (auto-generated on first docker compose up)
gitlab/config/gitlab-secrets.json

# GitLab Runner (auto-generated at container startup via entrypoint)
gitlab-runner/config/config.toml
gitlab-runner/config/.runner_system_id
gitlab-runner/config/certs/
